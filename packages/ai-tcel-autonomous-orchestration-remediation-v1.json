    "events": [],
    "rules": [
        {
            "ruleId": "AOR-014",
            "name": "Cross-tenant denial",
            "description": "Preventive/Critical. The universal AI-execution-boundary: deny any action, agent, or workflow reference that resolves outside the current tenant.",
            "triggerEvent": "RecordReceived",
            "priority": 5,
            "conditions": [
                {
                    "field": "recordType",
                    "operator": "Equals",
                    "value": "DataAccess"
                },
                {
                    "field": "crossTenant",
                    "operator": "Equals",
                    "value": "true"
                }
            ],
            "outcomeOnMatch": "Rejected",
            "reasonTemplate": "AOR-014: access denied - cross-tenant access is prohibited."
        }
    ],
