    "knowledgeAssets":  [
                            {
                                "assetId":  "tcel-data-warehouse-bi-control-catalog-2026",
                                "docKey":  "tcel-data-warehouse-bi-control-catalog",
                                "title":  "TCEL T9-017-Data-Warehouse-BI Control Catalog",
                                "assetType":  "ReferenceManual",
