    "rules":  [
                  {
                      "ruleId":  "RS-016",
                      "name":  "AI cannot trade",
                      "description":  "Preventive/Critical (AI Governance). AI execution boundary.",
                      "triggerEvent":  "RecordReceived",
                      "priority":  5,
                      "conditions":  [
                                         {
                                             "field":  "recordType",
                                             "operator":  "Equals",
                                             "value":  "AgentAction"
                                         },
                                         {
