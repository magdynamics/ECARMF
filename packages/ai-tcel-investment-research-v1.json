                                             "value":  "true"
                                         }
                                     ],
                      "outcomeOnMatch":  "Rejected",
                      "reasonTemplate":  "RS-016: denied - an AI agent may not take material actions; agents are advisory-only (AI Governance)."
                  },
                  {
                      "ruleId":  "RS-018",
                      "name":  "Cross-tenant research access",
                      "description":  "Preventive/Critical (Security). Cross-tenant denial.",
                      "triggerEvent":  "RecordReceived",
                      "priority":  5,
                      "conditions":  [
