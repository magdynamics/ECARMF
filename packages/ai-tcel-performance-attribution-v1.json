    "rules":  [
                  {
                      "ruleId":  "PF-012",
                      "name":  "AI certification boundary",
                      "description":  "Preventive/Critical (Model Risk). AI execution boundary.",
                      "triggerEvent":  "RecordReceived",
                      "priority":  5,
                      "conditions":  [
                                         {
                                             "field":  "recordType",
                                             "operator":  "Equals",
