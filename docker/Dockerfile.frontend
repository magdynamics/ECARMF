# ECARMF Platform Kernel Admin UI — multi-stage build
# Build context is the repository root: docker build -f docker/Dockerfile.frontend .

FROM node:22-alpine AS build
WORKDIR /source

COPY frontend/admin-ui/package.json frontend/admin-ui/package-lock.json ./
RUN npm ci --no-fund --no-audit

COPY frontend/admin-ui/ ./
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /source/dist /usr/share/nginx/html
EXPOSE 80
